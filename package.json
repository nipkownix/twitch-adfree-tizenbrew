{
  "name": "@nipkownix/twitch-adfree-tizenbrew",
  "version": "1.0.2",
  "description": "Enhanced Twitch app (original code by @adamff-dev)",
  "packageType": "mods",
  "appName": "Twitch AdFree",
  "websiteURL": "https://samsung.tv.twitch.tv/",
  "main": "dist/userScript.js",
  "author": "nipkow",
  "type": "module",
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:dev": "rollup -c rollup.config.js --environment BUILD:development",
    "type-check": "tsc -b"
  },
  "keys": [
    "MediaPlayPause",
    "MediaPlay",
    "MediaPause",
    "MediaStop",
    "MediaFastForward",
    "MediaRewind",
    "MediaTrackNext",
    "MediaTrackPrevious"
  ],
  "dependencies": {
    "@babel/runtime-corejs3": "^7.24.4",
    "regenerator-runtime": "^0.14.1",
    "tiny-sha256": "^1.0.2",
    "whatwg-fetch": "^3.6.20"
  },
  "repository": {
    "url": "https://github.com/nipkownix/twitch-adfree-tizenbrew"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/plugin-transform-runtime": "^7.24.3",
    "@babel/preset-env": "^7.24.4",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^26.0.1",
    "rollup-plugin-copy": "^3.5.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "babel-plugin-polyfill-regenerator": "^0.6.1",
    "rollup": "^4.18.0",
    "rollup-plugin-string": "^3.0.0",
    "typescript": "^5.4.4"
  }
}